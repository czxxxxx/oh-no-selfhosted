{
  "name": "oh-no-selfhosted",
  "version": "0.1.0",
  "description": "Self-hosted services dashboard with a production service installer.",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://github.com/czxxxxx/oh-no-selfhosted#readme",
  "bugs": {
    "url": "https://github.com/czxxxxx/oh-no-selfhosted/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czxxxxx/oh-no-selfhosted.git"
  },
  "keywords": [
    "dashboard",
    "homelab",
    "self-hosted"
  ],
  "engines": {
    "node": ">=22.5.0",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.7",
  "type": "module",
  "bin": {
    "oh-no-plugin": "scripts/plugin-cli.mjs",
    "oh-no-selfhosted": "bin/oh-no-selfhosted.mjs"
  },
  "files": [
    "LICENSE",
    "bin/oh-no-selfhosted.mjs",
    "bin/serviceManager.mjs",
    "builtins/",
    "dist/",
    "docs/plugin-registry.md",
    "examples/plugin-registry/",
    "plugin-sdk/",
    "server/api.mjs",
    "server/backgrounds.mjs",
    "server/favicon.mjs",
    "server/http.mjs",
    "server/icons.mjs",
    "server/index.mjs",
    "server/serviceTypeRegistry.mjs",
    "server/static.mjs",
    "server/storage.mjs",
    "server/storageMappers.mjs",
    "server/widgetPresentation.mjs",
    "server/widgetValidation.mjs",
    "server/enhanced/builtins/",
    "server/enhanced/jellyfinImageProxy.mjs",
    "server/enhanced/manifest.mjs",
    "server/enhanced/registry.mjs",
    "server/enhanced/runtime.mjs",
    "server/enhanced/serviceRefresh.mjs",
    "server/enhanced/widgetBinding.mjs",
    "server/enhanced/widgetTemplates.mjs",
    "server/integrations/builtins/",
    "server/integrations/codexUsage.mjs",
    "server/integrations/installer.mjs",
    "server/integrations/manifest.mjs",
    "server/integrations/registry.mjs",
    "server/integrations/runtime.mjs",
    "server/integrations/weather.mjs",
    "server/plugins/builtinRegistry.mjs",
    "server/plugins/builtinSource.mjs",
    "server/plugins/contract.mjs",
    "server/plugins/frontend.mjs",
    "server/plugins/installer.mjs",
    "server/plugins/registry.mjs",
    "scripts/plugin-cli.mjs",
    "server/widgets/installer.mjs",
    "server/widgets/manifest.mjs",
    "server/widgets/registry.mjs",
    "src/enhancedConfig.js",
    "src/enhancedWidgetContract.js",
    "src/pluginWidgetContract.js",
    "src/serviceCatalog.js",
    "src/widgetLayout.js",
    "src/widgetTemplates.js",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "api": "node --no-warnings=ExperimentalWarning server/index.mjs --serve-static false --host 127.0.0.1 --port 8787",
    "builtins:generate": "node scripts/generate-builtin-registry.mjs",
    "build": "vite build",
    "dev": "node scripts/dev.mjs",
    "pack:local": "npm pack",
    "pack:check": "node scripts/verify-package.mjs",
    "plugin:scaffold": "node scripts/plugin-cli.mjs scaffold",
    "plugin:validate": "node scripts/plugin-cli.mjs validate",
    "prebuild": "npm run builtins:generate",
    "prepack": "npm run build",
    "start": "node --no-warnings=ExperimentalWarning server/index.mjs",
    "service:install": "node bin/oh-no-selfhosted.mjs install",
    "service:restart": "node bin/oh-no-selfhosted.mjs restart",
    "service:status": "node bin/oh-no-selfhosted.mjs status",
    "service:uninstall": "node bin/oh-no-selfhosted.mjs uninstall",
    "test": "node --no-warnings=ExperimentalWarning ./node_modules/vitest/vitest.mjs run",
    "test:layout": "node scripts/check-widget-layout.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@vitejs/plugin-react": "5.0.4",
    "net-snmp": "^3.26.3",
    "ogl": "^1.0.11",
    "postcss": "8.5.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-grid-layout": "^2.2.3",
    "react-icons": "^5.7.0",
    "vite": "6.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "vitest": "^4.1.9"
  }
}
